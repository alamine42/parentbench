# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# handover
HANDOVER.md
.env*.local
.gstack/
.claude/scheduled_tasks.lock

# backfill audit reports (kept locally, surface diffs in commits not the JSON)
reports/

# beads daemon state (issues.jsonl is the source of truth, not these)
.beads/backup/
.beads/embeddeddolt/
.beads/beads.db
.beads/daemon.lock
.beads/daemon.log
.beads/last-touched
.beads/interactions.jsonl
